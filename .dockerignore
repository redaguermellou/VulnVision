# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Virtual envs ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Django ────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/staticfiles/
/media/

# ── Secrets – NEVER include in image ──────────────────────────
.env
*.pem
*.key
*.crt
secrets/

# ── Tests & coverage ──────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/

# ── IDE ───────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker build artifacts ─────────────────────────────────────
docker/postgres/data/
docker/nginx/certs/

# ── Node (if any frontend tooling) ────────────────────────────
node_modules/
npm-debug.log*
