# ════════════════════════════════════════════════════════════
# VulnVision – Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── Django core ──────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_a_long_random_string_here
DEBUG=False
PRODUCTION=True

# Comma-separated list of allowed hosts / IPs
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=vulnvision
DB_USER=vulnvision
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_HOST=postgres
DB_PORT=5432
# Expose Postgres on this host port (comment out in prod)
DB_EXTERNAL_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_HOST=redis
REDIS_PORT=6379
# Full broker URL including password:
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
# Expose Redis on this host port (comment out in prod)
REDIS_EXTERNAL_PORT=6379

# ── Nginx port binding ────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Django admin superuser (auto-created on first boot) ───────
DJANGO_SUPERUSER_EMAIL=admin@vulnvision.local
DJANGO_SUPERUSER_PASSWORD=Admin@12345  # Change immediately after first login!

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=VulnVision <noreply@vulnvision.com>

# ── AI / Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMMA_MODEL_NAME=gemma-3-27b-it

# ── External Vulnerability Databases ─────────────────────────
NVD_API_KEY=your_nvd_api_key_here   # Optional; get from https://nvd.nist.gov/developers/request-an-api-key

# ── OWASP ZAP ────────────────────────────────────────────────
ZAP_API_KEY=your_zap_api_key_here
ZAP_BASE_URL=http://localhost:8080

# ── Celery Flower monitoring UI ───────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password
FLOWER_PORT=5555

# ── Django cache (uses Redis by default via CELERY_BROKER_URL) ─
CACHE_BACKEND=django_redis.cache.RedisCache
CACHE_LOCATION=redis://:${REDIS_PASSWORD}@redis:6379/2
